{
  "settings": {
    "appName": "agent-ready react demo",
    "appUrl": "https://quixotic-viper-800.convex.site",
    "description": "Demo app for @waynesutton/agent-ready on React + Vite, hosted on Convex via static-hosting.",
    "widgetPosition": "floating-bottom-right",
    "widgetStatusVisible": true,
    "widgetShowFiles": false,
    "widgetShowAppName": true,
    "widgetShowDescription": false,
    "widgetShowMeta": true,
    "widgetShowScoreTab": false,
    "widgetCleanMode": false,
    "widgetShowHumanTab": true,
    "widgetShowMachineTab": true,
    "widgetShowChatLinks": true,
    "widgetShowChatGPT": true,
    "widgetShowClaude": true,
    "widgetShowPerplexity": true,
    "widgetColors": {
      "bg": "#1a1a1a",
      "border": "#333333",
      "textActive": "#e5e5e5",
      "textInactive": "#666666",
      "tabActiveBg": "#2a2a2a",
      "accent": "#ffffff"
    },
    "theme": "dark",
    "testMode": true,
    "cronEnabled": true,
    "cronIntervalHours": 24,
    "analyticsEnabled": true,
    "analyticsRequestRetentionDays": 90,
    "aiDescriptionsEnabled": true,
    "aiProvider": "claude",
    "fullTxtEnabled": true,
    "permissiveMode": false,
    "versioningEnabled": true,
    "contentSignals": { "aiTrain": true, "search": true, "aiInput": true },
    "markdownNegotiation": true,
    "discoveryHeaders": true,
    "robotsTxtEnabled": true,
    "robotsTxtAllowAiBots": true,
    "sitemapEnabled": true,
    "agentSkillsEnabled": true,
    "readinessEndpointEnabled": true
  },
  "pages": [
    {
      "title": "Overview",
      "path": "/",
      "description": "Landing page for the React demo.",
      "status": "published",
      "order": 10
    },
    {
      "title": "Settings",
      "path": "/settings",
      "description": "Settings panel with draft, publish, archive, rollback, and version history controls.",
      "status": "published",
      "order": 20
    },
    {
      "title": "Analytics",
      "path": "/analytics",
      "description": "Agent request dashboard showing traffic by agent and by file type.",
      "status": "published",
      "order": 30
    }
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/llms.txt",
      "description": "Returns the generated llms.txt summary.",
      "group": "Discovery",
      "status": "published"
    },
    {
      "method": "GET",
      "path": "/agents.md",
      "description": "Returns the generated agents.md with API instructions.",
      "group": "Discovery",
      "status": "published"
    }
  ]
}
