{
  "settings": {
    "appName": "agent-ready SvelteKit demo",
    "appUrl": "https://your-deployment.convex.site",
    "description": "Demo app for @waynesutton/agent-ready on SvelteKit, hosted on Convex via static-hosting.",
    "widgetPosition": "floating-bottom-right",
    "widgetStatusVisible": true,
    "widgetShowFiles": true,
    "widgetShowAppName": true,
    "widgetShowDescription": true,
    "widgetShowMeta": true,
    "widgetShowScoreTab": false,
    "widgetColors": {
      "bg": "#1a1a1a",
      "border": "#333333",
      "textActive": "#e5e5e5",
      "textInactive": "#666666",
      "tabActiveBg": "#2a2a2a",
      "accent": "#ffffff"
    },
    "theme": "dark",
    "testMode": true,
    "cronEnabled": true,
    "cronIntervalHours": 24,
    "analyticsEnabled": true,
    "analyticsRequestRetentionDays": 90,
    "aiDescriptionsEnabled": false,
    "aiProvider": "claude",
    "fullTxtEnabled": true,
    "permissiveMode": false,
    "versioningEnabled": true,
    "contentSignals": { "aiTrain": true, "search": true, "aiInput": true },
    "markdownNegotiation": true,
    "discoveryHeaders": true,
    "robotsTxtEnabled": true,
    "robotsTxtAllowAiBots": true,
    "sitemapEnabled": true,
    "agentSkillsEnabled": true,
    "readinessEndpointEnabled": true
  },
  "pages": [
    { "title": "Overview", "path": "/", "description": "Landing page for the Svelte demo.", "status": "published", "order": 10 },
    { "title": "Settings", "path": "/settings", "description": "Settings controls.", "status": "published", "order": 20 },
    { "title": "Analytics", "path": "/analytics", "description": "Analytics dashboard.", "status": "published", "order": 30 }
  ],
  "endpoints": []
}
